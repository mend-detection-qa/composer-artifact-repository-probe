{
    "name": "acme/artifact-test",
    "description": "Composer probe: artifact-type repository detection test.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "acme/local-lib": "^1.0"
    },
    "repositories": [
        {
            "type": "artifact",
            "url": "./artifacts"
        }
    ],
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}